{
  "name": "pinterest-wallpaper-app",
  "version": "2.0.0",
  "description": "Modern Pinterest wallpaper finder with React",
  "scripts": {
    "server": "node server.js",
    "client": "cd client && npm start",
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "build": "cd client && npm run build",
    "install-all": "npm install && cd client && npm install"
  },
  "dependencies": {
    "express": "^4.18.0",
    "cors": "^2.8.5",
    "puppeteer": "^22.0.0"
  },
  "devDependencies": {
    "concurrently": "^8.2.0"
  }
}
